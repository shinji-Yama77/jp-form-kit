{
  "name": "jp-form-schemas",
  "version": "0.1.0",
  "description": "TypeScript schema library and PDF overlay toolkit for Japanese government forms",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "pdfjs-dist": "^4.0.0",
    "pdf-lib": "^1.17.1",
    "@pdf-lib/fontkit": "^1.1.1"
  },
  "keywords": ["japan", "japanese", "forms", "pdf", "schema", "ward", "bureaucracy", "expat"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shinchan/jp-form-schemas"
  }
}
