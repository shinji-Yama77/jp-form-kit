{
  "name": "jp-form-kit",
  "version": "0.1.0",
  "description": "TypeScript schema library and PDF overlay toolkit for Japanese government forms",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/assets && cp -r assets/. dist/assets",
    "lint": "eslint scripts",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "eslint": "^10.2.0",
    "pdfjs-dist": "^4.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "japan",
    "japanese",
    "forms",
    "pdf",
    "schema",
    "ward",
    "bureaucracy",
    "expat"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shinchan/jp-form-schemas"
  }
}
