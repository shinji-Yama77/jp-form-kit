{
  "name": "jp-form-kit",
  "version": "0.1.2",
  "description": "TypeScript schema library and PDF overlay toolkit for Japanese government forms",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && mkdir -p dist/assets && cp -r assets/. dist/assets",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint scripts",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release:check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build && npm pack",
    "prepublishOnly": "npm run release:check"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "pdf-lib": "^1.17.1"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.2.0",
    "pdfjs-dist": "^4.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "japan",
    "japanese",
    "forms",
    "pdf",
    "schema",
    "ward",
    "bureaucracy",
    "expat"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shinji-Yama77/jp-form-kit"
  }
}
